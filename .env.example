# Environment Configuration
# Copy this file to .env and fill in your values

# Application Mode
# Options: development, production, test
NODE_ENV=development

# API Configuration
# Base URL for the backend API
VITE_API_URL=http://127.0.0.1:8000/api

# Debug Mode
# Enable additional debug logging (development only)
# Options: true, false
VITE_DEBUG=false

# Google Analytics
# Your Google Analytics tracking ID
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Feature Flags
# Enable/disable specific features
# VITE_FEATURE_ANALYTICS=true
# VITE_FEATURE_CHAT=false

# External Services
# Add your service keys here (never commit actual keys)
# VITE_MAPS_API_KEY=your_maps_key_here
# VITE_RECAPTCHA_SITE_KEY=your_recaptcha_key_here
