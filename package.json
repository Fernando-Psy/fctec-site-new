{
  "name": "fctec-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Modern, high-performance website for FCBJ Desenvolvimento",
  "author": "FCBJ Desenvolvimento",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/fctec-site.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/fctec-site/issues"
  },
  "homepage": "https://github.com/yourusername/fctec-site#readme",
  "keywords": [
    "react",
    "vite",
    "tailwind",
    "website",
    "web-development"
  ],
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite",
    "analyze": "vite build --mode analyze"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bootstrap": "^5.3.2",
    "firebase": "^12.12.1",
    "react": "^18.2.0",
    "react-bootstrap": "^2.9.1",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.11.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.1.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "postcss": "^8.5.6",
    "prettier": "^3.1.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^3.4.17",
    "terser": "^5.46.0",
    "typescript-eslint": "^8.47.0",
    "vite": "^4.5.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-imagemin": "^0.6.1"
  }
}
